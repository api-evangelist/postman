{
  "info": {
    "_postman_id": "f263b81d-d4b9-4fb5-977b-38ba4be210a0",
    "name": "Postman Webhooks API",
    "description": "The Postman Webhooks API enables you to create webhooks that trigger\ncollection runs with custom payloads. Webhooks provide a way to integrate\nPostman with external systems and automate workflows based on incoming\nevents. When a webhook URL receives a POST request, it triggers a\ncollection run with the incoming payload available as variables.\n\n## Authentication\nAll requests require an API key passed in the `x-api-key` header.\n\n## Rate Limits\nStandard Postman API rate limits apply.\n\n\nContact Support:\n Name: Postman Developer Support\n Email: help@postman.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:05:34.000Z",
    "updatedAt": "2026-06-05T13:05:34.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-f263b81d-d4b9-4fb5-977b-38ba4be210a0"
  },
  "item": [
    {
      "name": "webhooks",
      "item": [
        {
          "name": "Postman Create a webhook",
          "id": "9d2dfbe2-6a89-4e7f-b311-4e7523131ae5",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"webhook\": {\n    \"name\": \"<string>\",\n    \"collection\": \"<string>\"\n  }\n}",
              "options": {
                "raw": {
                  "headerFamily": "json",
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/webhooks?workspace=<string>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "webhooks"
              ],
              "query": [
                {
                  "description": "The workspace ID to create the webhook in.",
                  "key": "workspace",
                  "value": "<string>"
                }
              ]
            },
            "description": "Creates a webhook that triggers a collection run when its generated URL receives a POST request. The incoming request body is available as variables during the collection run."
          },
