  "info": {
    "_postman_id": "ecd451fd-594c-4401-8eda-3d594415a751",
    "name": "Postman Webhooks API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Postman Webhooks API enables you to create webhooks that trigger\ncollection runs with custom payloads. Webhooks provide a way to integrate\nPostman with external systems and automate workflows based on incoming\nevents. When a webhook URL receives a POST request, it triggers a\ncollection run with the incoming payload available as variables.\n\n## Authentication\nAll requests require an API key passed in the `x-api-key` header.\n\n## Rate Limits\nStandard Postman API rate limits apply.\n\n\nContact Support:\n Name: Postman Developer Support\n Email: help@postman.com",
      "type": "text/plain"
    }
  }
