          "name": "Postman Create a webhook",
          "request": {
            "name": "Postman Create a webhook",
            "description": {
              "content": "Creates a webhook that triggers a collection run when its generated URL receives a POST request. The incoming request body is available as variables during the collection run.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "webhooks"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "workspace",
                  "value": "<string>",
                  "description": "The workspace ID to create the webhook in."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"webhook\": {\n    \"name\": \"<string>\",\n    \"collection\": \"<string>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
