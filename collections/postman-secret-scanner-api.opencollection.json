{
  "opencollection": "1.0.0",
  "info": {
    "name": "Postman Secret Scanner API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "x-api-key",
      "value": "{{x-api-key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Secret Scanner",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Postman Get detected secrets",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/secret-scanner/detected-secrets",
            "params": [
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Pagination cursor for the next page."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return."
              },
              {
                "name": "since",
                "value": "",
                "type": "query",
                "description": "Return secrets detected after this date (ISO 8601)."
              },
              {
                "name": "until",
                "value": "",
                "type": "query",
                "description": "Return secrets detected before this date (ISO 8601)."
              },
              {
                "name": "statuses",
                "value": "",
                "type": "query",
                "description": "Filter by resolution status (comma-separated)."
              },
              {
                "name": "resourceTypes",
                "value": "",
                "type": "query",
                "description": "Filter by resource type (comma-separated)."
              },
              {
                "name": "workspaceIds",
                "value": "",
                "type": "query",
                "description": "Filter by workspace IDs (comma-separated)."
              },
              {
                "name": "secretTypes",
                "value": "",
                "type": "query",
                "description": "Filter by secret type (comma-separated)."
              }
            ]
          },
          "docs": "Gets a list of secrets detected across your team's Postman entities (collections, environments, etc.). Returns secret metadata including the type of secret, where it was found, and its resolution status."
        },
        {
          "info": {
            "name": "Postman Get a detected secret",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/secret-scanner/detected-secrets/:secretId",
            "params": [
              {
                "name": "secretId",
                "value": "",
                "type": "path",
                "description": "The detected secret's unique ID."
              }
            ]
          },
          "docs": "Gets detailed information about a specific detected secret, including where it was found and its resolution history."
        },
        {
          "info": {
            "name": "Postman Resolve a detected secret",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.getpostman.com/secret-scanner/detected-secrets/:secretId",
            "params": [
              {
                "name": "secretId",
                "value": "",
                "type": "path",
                "description": "The detected secret's unique ID."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates the resolution status of a detected secret. You can mark it as revoked, a false positive, or an accepted risk."
        },
        {
          "info": {
            "name": "Postman Get locations of a detected secret",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/secret-scanner/detected-secrets/:secretId/locations",
            "params": [
              {
                "name": "secretId",
                "value": "",
                "type": "path",
                "description": "The detected secret's unique ID."
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Gets all locations where a detected secret was found across your Postman entities."
        },
        {
          "info": {
            "name": "Postman Get supported secret types",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/secret-scanner/secret-types"
          },
          "docs": "Gets a list of all secret types that the scanner can detect, including their names and descriptions."
        }
      ]
    }
  ],
  "bundled": true
}