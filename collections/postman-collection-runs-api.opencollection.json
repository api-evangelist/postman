{
  "opencollection": "1.0.0",
  "info": {
    "name": "Postman Collection Runs API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "x-api-key",
      "value": "{{x-api-key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Collection Runs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Postman Get collection runs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/collections/:collectionId/runs",
            "params": [
              {
                "name": "collectionId",
                "value": "",
                "type": "path",
                "description": "The collection's unique ID or UID."
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Pagination cursor for the next page of results."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return."
              },
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by run status."
              },
              {
                "name": "source",
                "value": "",
                "type": "query",
                "description": "Filter by run source."
              }
            ]
          },
          "docs": "Gets the run history for a collection. Returns a list of past runs with their status, timing, and summary statistics."
        },
        {
          "info": {
            "name": "Postman Get a collection run",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/collections/:collectionId/runs/:runId",
            "params": [
              {
                "name": "collectionId",
                "value": "",
                "type": "path",
                "description": "The collection's unique ID or UID."
              },
              {
                "name": "runId",
                "value": "",
                "type": "path",
                "description": "The run's unique ID."
              }
            ]
          },
          "docs": "Gets detailed information about a specific collection run, including individual request results, test assertions, and response data."
        }
      ]
    }
  ],
  "bundled": true
}