{
  "opencollection": "1.0.0",
  "info": {
    "name": "Postman Webhooks API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "x-api-key",
      "value": "{{x-api-key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Webhooks",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Postman Create a webhook",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.getpostman.com/webhooks",
            "params": [
              {
                "name": "workspace",
                "value": "",
                "type": "query",
                "description": "The workspace ID to create the webhook in."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a webhook that triggers a collection run when its generated URL receives a POST request. The incoming request body is available as variables during the collection run."
        }
      ]
    }
  ],
  "bundled": true
}