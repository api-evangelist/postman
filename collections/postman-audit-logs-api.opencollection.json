{
  "opencollection": "1.0.0",
  "info": {
    "name": "Postman Audit Logs API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "x-api-key",
      "value": "{{x-api-key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Audit Logs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Postman Get audit logs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/audit/logs",
            "params": [
              {
                "name": "since",
                "value": "",
                "type": "query",
                "description": "Return audit events since this date (ISO 8601)."
              },
              {
                "name": "until",
                "value": "",
                "type": "query",
                "description": "Return audit events until this date (ISO 8601)."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of results to return."
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Pagination cursor for the next page of results."
              },
              {
                "name": "orderBy",
                "value": "",
                "type": "query",
                "description": "Sort order for results."
              }
            ]
          },
          "docs": "Gets team audit log events. You can filter by date range, event name, and user. Audit logs include user sign-ins, collection changes, workspace modifications, team membership changes, and other security and governance events."
        }
      ]
    }
  ],
  "bundled": true
}