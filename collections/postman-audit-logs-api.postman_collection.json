          "request": {
            "name": "Postman Get audit logs",
            "description": {
              "content": "Gets team audit log events. You can filter by date range, event name, and user. Audit logs include user sign-ins, collection changes, workspace modifications, team membership changes, and other security and governance events.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "audit",
                "logs"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "since",
                  "value": "<dateTime>",
                  "description": "Return audit events since this date (ISO 8601)."
                },
                {
                  "disabled": false,
                  "key": "until",
                  "value": "<dateTime>",
                  "description": "Return audit events until this date (ISO 8601)."
                },
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "50",
                  "description": "Maximum number of results to return."
                },
                {
                  "disabled": false,
                  "key": "cursor",
                  "value": "<string>",
                  "description": "Pagination cursor for the next page of results."
                },
                {
                  "disabled": false,
                  "key": "orderBy",
                  "value": "desc",
                  "description": "Sort order for results."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
