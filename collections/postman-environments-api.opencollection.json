{
  "opencollection": "1.0.0",
  "info": {
    "name": "Postman Environments API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "x-api-key",
      "value": "{{x-api-key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Environments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Postman Get all environments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/environments",
            "params": [
              {
                "name": "workspace",
                "value": "",
                "type": "query",
                "description": "Filter environments by workspace ID."
              }
            ]
          },
          "docs": "Gets all environments for the authenticated user. The response includes basic metadata for each environment. To get the full environment with variables, use the single environment endpoint."
        },
        {
          "info": {
            "name": "Postman Create an environment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.getpostman.com/environments",
            "params": [
              {
                "name": "workspace",
                "value": "",
                "type": "query",
                "description": "The workspace ID to create the environment in."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new environment with the specified name and variables. You can optionally specify a workspace to create the environment in."
        },
        {
          "info": {
            "name": "Postman Get an environment",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.getpostman.com/environments/:environmentId",
            "params": [
              {
                "name": "environmentId",
                "value": "",
                "type": "path",
                "description": "The environment's unique ID or UID."
              }
            ]
          },
          "docs": "Gets information about a single environment, including its variables. Variable values that are marked as secret will be masked in the response."
        },
        {
          "info": {
            "name": "Postman Update an environment",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.getpostman.com/environments/:environmentId",
            "params": [
              {
                "name": "environmentId",
                "value": "",
                "type": "path",
                "description": "The environment's unique ID or UID."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates an existing environment. You can update the name and variables. This replaces the entire set of variables with the values provided."
        },
        {
          "info": {
            "name": "Postman Delete an environment",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.getpostman.com/environments/:environmentId",
            "params": [
              {
                "name": "environmentId",
                "value": "",
                "type": "path",
                "description": "The environment's unique ID or UID."
              }
            ]
          },
          "docs": "Deletes an existing environment. This action is irreversible."
        }
      ]
    }
  ],
  "bundled": true
}